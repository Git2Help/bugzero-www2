---
import Layout from "../../components/Layout.astro";
import Header from "../../components/Header.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import CtaSection from "../../components/CtaSection.astro";
import Footer from "../../components/Footer.astro";
---

<Layout title="BugZero | Contact">
  <Header />

  <section class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 px-6 z-10">
    <div class="max-w-7xl mx-auto">
      <SectionHeader
        title="Contactez-nous"
        description="Une question ? Un problème ? Notre équipe est là pour vous répondre."
      />
      <div class="grid lg:grid-cols-2 gap-16 max-w-5xl mx-auto mt-16">
        <div class="space-y-6">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-[#EEF9FF] rounded-lg flex items-center justify-center text-[#00AEEF]">
              <i data-lucide="phone" class="w-6 h-6"></i>
            </div>
            <div>
              <p class="font-bold text-neutral-900">06 78 56 54 30</p>
              <p class="text-sm text-neutral-500">Du lundi au vendredi, 9h-18h</p>
            </div>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-[#EEF9FF] rounded-lg flex items-center justify-center text-[#00AEEF]">
              <i data-lucide="mail" class="w-6 h-6"></i>
            </div>
            <div>
              <p class="font-bold text-neutral-900">bonjour@bugzero.fr</p>
            </div>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-[#EEF9FF] rounded-lg flex items-center justify-center text-[#00AEEF]">
              <i data-lucide="map-pin" class="w-6 h-6"></i>
            </div>
            <div>
              <p class="font-bold text-neutral-900">9, Allée Lazare Sauvaigo</p>
              <p class="text-sm text-neutral-500">98000 Monaco</p>
            </div>
          </div>
        </div>
        <div class="bg-white border border-neutral-200 rounded-xl p-8 shadow-sm">
          <h3 class="font-bold text-xl text-neutral-900 mb-6">Envoyez-nous un message</h3>
          <form class="space-y-4">
            <div>
              <input type="text" placeholder="Nom" class="w-full border border-neutral-200 rounded-lg px-4 py-3 text-sm">
            </div>
            <div>
              <input type="email" placeholder="Email" class="w-full border border-neutral-200 rounded-lg px-4 py-3 text-sm">
            </div>
            <div>
              <textarea placeholder="Votre message" rows="4" class="w-full border border-neutral-200 rounded-lg px-4 py-3 text-sm"></textarea>
            </div>
            <button type="submit" class="w-full px-8 py-4 bg-[#00AEEF] text-white font-sans font-medium text-lg rounded-md hover:bg-[#0090C0] transition-all">
              Envoyer
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <Footer
    address="9, Allée Lazare Sauvaigo<br/>98000 Monaco"
    phone="06 78 56 54 30"
    email="bonjour@bugzero.fr"
  />
</Layout>