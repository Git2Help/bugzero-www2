---
import Layout from "../components/Layout.astro";
import Header from "../components/Header.astro";
import HeroSection from "../components/HeroSection.astro";
import ServiceCard from "../components/ServiceCard.astro";
import FeatureCard from "../components/FeatureCard.astro";
import SectionHeader from "../components/SectionHeader.astro";
import StepSection from "../components/StepSection.astro";
import TestimonialCard from "../components/TestimonialCard.astro";
import CtaSection from "../components/CtaSection.astro";
import Footer from "../components/Footer.astro";
---

<Layout>
  <Header />

  <HeroSection
    badge="Particuliers • Pros • Monaco"
    title="Votre PC plante, votre entreprise"
    titleHighlight="est a l'arret ?"
    description="Bugzero intervient en 30 minutes. Diagnostic gratuit, solutions immediates."
    ctaPrimary={{ label: "Je regle mon probleme maintenant", href: "/contact" }}
    ctaSecondary={{ label: "Nos services", href: "/professionnel" }}
    showStatusCard={true}
  />

  <section id="services" class="relative py-24 bg-neutral-50 border-t border-neutral-200 z-10">
    <div class="max-w-7xl mx-auto px-6">
      <SectionHeader
        title="Trois formules, zero engagement"
        description="Depannage express, infogerance, cybersecurite, visibilite web. On s'occupe de tout."
      />
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <ServiceCard
          icon="user"
          title="Particuliers"
          description="Depannage express, installation, conseils. A distance ou a domicile, sans stress."
        />
        <ServiceCard
          icon="building"
          iconBg="bg-[#F9FCE5]"
          iconColor="text-[#C4D600]"
          title="Professionnels"
          description="Infogerance, cybersecurite, visibilite web. Votre service IT cle-en-main, sans engagement."
        />
        <ServiceCard
          icon="euro"
          iconBg="bg-neutral-100"
          iconColor="text-neutral-600"
          title="Fonds Bleu Monaco"
          description="Jusqu'a 70% de subventions pour votre site, SEO, appli. On monte le dossier gratuitement."
        />
      </div>
    </div>
  </section>

  <section id="about" class="relative py-24 bg-white z-10">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-12 gap-16 items-start">
        <div class="lg:col-span-5 lg:sticky lg:top-32">
          <h2 class="font-sans text-4xl font-bold tracking-tight text-neutral-900 mb-6">Pourquoi Bugzero ?</h2>
          <div class="w-20 h-1.5 bg-[#00AEEF] rounded-full mb-6"></div>
          <p class="text-2xl text-neutral-800 font-semibold leading-snug">15 ans d'expertise a Monaco et PACA.</p>
          <p class="mt-4 text-lg text-neutral-600">800+ depannages reussis, 98% de satisfaction. Intervention en moins de 2h (appel avant 14h).</p>
        </div>
        <div class="lg:col-span-7 grid sm:grid-cols-2 gap-6">
          <FeatureCard
            icon="clock"
            title="15 ans d'expertise"
            description="A Monaco et PACA. Des techniciens qui connaissent votre environnement."
          />
          <FeatureCard
            icon="zap"
            iconColor="text-[#C4D600]"
            title="Intervention 2h max"
            description="Moins de 2h si vous appelez avant 14h. Reactivite garantie."
          />
          <FeatureCard
            icon="smile"
            iconColor="text-neutral-600"
            title="98% de satisfaction"
            description="+800 depannages reussis. Partenaires Monaco Cloud, Dell, Bitdefender."
          />
          <FeatureCard
            icon="map-pin"
            title="Proximite locale"
            description="Un partenaire de confiance a Monaco, Nice et Menton."
          />
        </div>
      </div>
    </div>
  </section>

  <StepSection
    title="Comment ca marche"
    description="Une methode simple et eprouvee : diagnostic, solution, suivi."
    steps={[
      { number: "1", title: "Diagnostic gratuit", description: "Analyse de votre probleme en 30 minutes. Sans engagement, sans surprise." },
      { number: "2", title: "Solution immediate", description: "Reparation a distance ou sur site. Prix transparents, devis prealable.", circled: true },
      { number: "3", title: "Suivi garanti", description: "On ne vous lache pas apres l'intervention. Satisfaction ou resolue sans frais." },
    ]}
  />

  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <SectionHeader title="Ils nous font confiance" />
      <div class="grid md:grid-cols-3 gap-8">
        <TestimonialCard
          quote="Frederic a recupere tous mes fichiers en 45 minutes. Incroyable reactivite !"
          name="Sophie"
          role="Particuliere, Nice"
        />
        <TestimonialCard
          quote="Bugzero gere notre parc info depuis 3 ans, zero souci. Support reactif et professionnel."
          name="Cabinet Avocats Associes"
          role="Monaco"
        />
        <TestimonialCard
          quote="Bugzero a cree notre boutique en ligne en 3 semaines. Nos ventes ont triple."
          name="Commercant"
          role="Monaco"
        />
      </div>
    </div>
  </section>

  <CtaSection
    title="Pret a resoudre votre probleme ?"
    description="Appelez le 06 78 56 54 30 ou prenez rendez-vous en ligne. Intervention en moins de 2h."
    buttonLabel="Je regle mon probleme maintenant"
  />

  <Footer
    address="9, Allee Lazare Sauvaigo<br/>98000 Monaco"
    phone="06 78 56 54 30"
    email="bonjour@bugzero.fr"
  />
</Layout>