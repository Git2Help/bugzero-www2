---
import Layout from "../../components/Layout.astro";
import Header from "../../components/Header.astro";
import HeroSection from "../../components/HeroSection.astro";
import ServiceCard from "../../components/ServiceCard.astro";
import FeatureCard from "../../components/FeatureCard.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import CtaSection from "../../components/CtaSection.astro";
import Footer from "../../components/Footer.astro";
---

<Layout title="BugZero | Particulier - Dépannage informatique Monaco">
  <Header />

  <HeroSection
    badge="PARTICULIER"
    title="Un écran noir, un virus, un ordi"
    titleHighlight="qui rame ?"
    description="On le répare à distance en 30 minutes. Sans vous déplacer, sans stress. 49 € HT le dépannage."
    ctaPrimary={{ label: "Je veux un dépannage immédiat", href: "/contact" }}
    showStatusCard={false}
  />

  <section class="relative py-24 bg-neutral-50 border-t border-neutral-200 z-10">
    <div class="max-w-7xl mx-auto px-6">
      <SectionHeader
        title="Dépannage à distance"
        description="Connexion sécurisée, diagnostic et résolution en direct. 30 minutes max."
      />
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <ServiceCard
          icon="monitor"
          iconBg="bg-[#EEF9FF]"
          iconColor="text-[#00AEEF]"
          title="30 minutes, 49 € HT"
          description="Dépannage à distance en 30 min chrono. Connexion sécurisée, résultat garanti."
        />
        <ServiceCard
          icon="clock"
          iconBg="bg-[#F9FCE5]"
          iconColor="text-[#C4D600]"
          title="Sans engagement"
          description="Pas d'abonnement, pas de surprise. Vous payez uniquement l'intervention, sur devis préalable."
        />
        <ServiceCard
          icon="shield-check"
          iconBg="bg-neutral-100"
          iconColor="text-neutral-600"
          title="Connexion sécurisée"
          description="Accès chiffré de bout en bout. Vous contrôlez la session à tout moment."
        />
      </div>
    </div>
  </section>

  <section class="relative py-24 bg-white z-10">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-12 gap-16 items-start">
        <div class="lg:col-span-5 lg:sticky lg:top-32">
          <h2 class="font-sans text-4xl font-bold tracking-tight text-neutral-900 mb-6">Dépannage sur site</h2>
          <div class="w-20 h-1.5 bg-[#00AEEF] rounded-full mb-6"></div>
          <p class="text-2xl text-neutral-800 font-semibold leading-snug">Nous venons chez vous.</p>
          <p class="mt-4 text-lg text-neutral-600">Hardware, panne, virus. 89 € HT/heure à Monaco, Nice et Menton. Intervention le jour même (appel avant 14h).</p>
        </div>
        <div class="lg:col-span-7 grid sm:grid-cols-2 gap-6">
          <FeatureCard
            icon="map-pin"
            title="Monaco"
            description="Intervention dans tout Monaco. Sous 2h ouvrées."
          />
          <FeatureCard
            icon="map-pin"
            iconColor="text-[#C4D600]"
            title="Nice"
            description="Dépannage à domicile sur Nice et sa métropole."
          />
          <FeatureCard
            icon="map-pin"
            iconColor="text-neutral-600"
            title="Menton"
            description="Nous couvrons Menton et la vallée de la Roya."
          />
          <FeatureCard
            icon="clock"
            title="7j/7"
            description="Interventions possibles week-end et jours feries pour les urgences."
          />
        </div>
      </div>
    </div>
  </section>

  <section class="relative py-24 bg-neutral-50 border-t border-neutral-200 z-10">
    <div class="max-w-7xl mx-auto px-6">
      <SectionHeader
        title="Maintenance préventive"
        description="Nettoyage complet + antivirus + sauvegarde. 89 € HT/heure."
      />
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <ServiceCard
          icon="spray-can"
          iconBg="bg-[#EEF9FF]"
          iconColor="text-[#00AEEF]"
          title="Nettoyage complet"
          description="Physique et logiciel : poussiere, fichiers temporaires, registre, optimisation."
        />
        <ServiceCard
          icon="shield"
          iconBg="bg-[#F9FCE5]"
          iconColor="text-[#C4D600]"
          title="Antivirus & Sécurité"
          description="Installation et configuration antivirus. Protection anti-ransomware."
        />
        <ServiceCard
          icon="hard-drive"
          iconBg="bg-neutral-100"
          iconColor="text-neutral-600"
          title="Sauvegarde"
          description="Sauvegarde automatique de vos données. Cloud ou disque externe."
        />
      </div>
    </div>
  </section>

  <section class="relative py-24 bg-white z-10">
    <div class="max-w-7xl mx-auto px-6">
      <SectionHeader
        title="Formation sur mesure"
        description="Bureautique, Internet, sauvegarde. À partir de 89 € HT/heure."
      />
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <ServiceCard
          icon="book-open"
          iconBg="bg-[#EEF9FF]"
          iconColor="text-[#00AEEF]"
          title="Bureautique"
          description="Word, Excel, PowerPoint. Les bases comme les fonctions avancées."
        />
        <ServiceCard
          icon="globe"
          iconBg="bg-[#F9FCE5]"
          iconColor="text-[#C4D600]"
          title="Internet"
          description="Navigation, messagerie, démarches en ligne, sécurité."
        />
        <ServiceCard
          icon="hard-drive"
          iconBg="bg-neutral-100"
          iconColor="text-neutral-600"
          title="Sauvegarde"
          description="Sauvegarder vos données, les protéger, les restaurer."
        />
      </div>
    </div>
  </section>

  <CtaSection
    title="Un problème informatique ?"
    description="Appelez le 06 78 56 54 30 ou prenez rendez-vous en ligne. Intervention le jour même avant 14h."
    buttonLabel="Prendre rendez-vous"
  />

  <Footer
    address="9, Allée Lazare Sauvaigo<br/>98000 Monaco"
    phone="06 78 56 54 30"
    email="bonjour@bugzero.fr"
  />
</Layout>