---
import Layout from "../../components/Layout.astro";
import Header from "../../components/Header.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import CtaSection from "../../components/CtaSection.astro";
import Footer from "../../components/Footer.astro";
---

<Layout title="BugZero | Qui sommes-nous">
  <Header />

  <section class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 px-6 z-10">
    <div class="max-w-7xl mx-auto">
      <SectionHeader
        title="Qui se cache derriere Bugzero ?"
        description="Une équipe monégasque de passionnés, à votre service depuis 15 ans."
      />
      <div class="grid lg:grid-cols-2 gap-16 items-start max-w-5xl mx-auto mt-16">
        <div class="space-y-6 text-lg text-neutral-600">
          <p>Bugzero est la marque grand public et professionnelle de Helperiance (<a href="https://www.helperiance.com" class="text-[#00AEEF] hover:underline">www.helperiance.com</a>), societe fondee en 2010 par <strong>Johan Chauvet</strong> (CEO) et <strong>Lyonel Sireuille</strong> (associe).</p>
          <p>Notre mission : rendre l'informatique simple, fiable et sécurisée pour les particuliers comme pour les entreprises.</p>
          <p>Basés au <strong>9, Allée Lazare Sauvaigo à Monaco</strong>, nous intervenons dans tout le bassin monégasque, de Nice à Menton.</p>
          <p>Bugzero s'appuie sur une équipe de techniciens certifiés (Frédéric, Alex, Camelia) et des partenaires de confiance : Monaco Cloud, Dell, Bitdefender.</p>
        </div>
        <div class="bg-neutral-50 border border-neutral-100 rounded-xl p-8">
          <h3 class="font-bold text-xl text-neutral-900 mb-6">Contact</h3>
          <div class="space-y-4">
            <div class="flex items-center gap-3">
              <i data-lucide="phone" class="w-5 h-5 text-[#00AEEF]"></i>
              <span class="text-neutral-700">06 78 56 54 30</span>
            </div>
            <div class="flex items-center gap-3">
              <i data-lucide="mail" class="w-5 h-5 text-[#00AEEF]"></i>
              <span class="text-neutral-700">bonjour@bugzero.fr</span>
            </div>
            <div class="flex items-center gap-3">
              <i data-lucide="map-pin" class="w-5 h-5 text-[#00AEEF]"></i>
              <span class="text-neutral-700">9, Allée Lazare Sauvaigo, 98000 Monaco</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer
    address="9, Allée Lazare Sauvaigo<br/>98000 Monaco"
    phone="06 78 56 54 30"
    email="bonjour@bugzero.fr"
  />
</Layout>