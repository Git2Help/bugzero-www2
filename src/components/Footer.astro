---
export interface Props {
  address?: string;
  phone?: string;
  email?: string;
}

const { address = "9, Allée Lazare Sauvaigo<br/>98000 Monaco", phone = "06 78 56 54 30", email = "bonjour@bugzero.fr" } = Astro.props;
---

<footer class="relative z-10 border-t border-neutral-200 bg-white py-16">
  <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-4 gap-12 text-neutral-600 font-sans">
    <div class="md:col-span-2">
      <div class="font-sans font-bold text-3xl tracking-tighter flex items-center select-none mb-6">
        <span class="text-[#00AEEF]">BUG</span>
        <span class="text-[#C4D600]">ZERO</span>
      </div>
      <p class="mb-6 max-w-sm">
        Dépannage &amp; infogérance informatique pour particuliers et professionnels à Monaco, Nice et Menton.
      </p>
      <div class="flex items-center gap-4">
        <a href="#" class="w-10 h-10 rounded-full bg-neutral-100 flex items-center justify-center hover:bg-[#00AEEF] hover:text-white transition-colors">
          <i data-lucide="linkedin" class="w-5 h-5"></i>
        </a>
        <a href="#" class="w-10 h-10 rounded-full bg-neutral-100 flex items-center justify-center hover:bg-[#00AEEF] hover:text-white transition-colors">
          <i data-lucide="twitter" class="w-5 h-5"></i>
        </a>
      </div>
    </div>
    <div>
      <h4 class="font-bold text-neutral-900 mb-4 uppercase text-sm tracking-wider">Services</h4>
      <ul class="space-y-3">
        <li><a href="/professionnel/" class="hover:text-[#00AEEF] transition-colors">Infogérance</a></li>
        <li><a href="/audit-securite/" class="hover:text-[#00AEEF] transition-colors">Audit de sécurité</a></li>
        <li><a href="/maintenance-pro/" class="hover:text-[#00AEEF] transition-colors">Maintenance Pro</a></li>
        <li><a href="/creation-site/" class="hover:text-[#00AEEF] transition-colors">Création de site</a></li>
      </ul>
    </div>
    <div>
      <h4 class="font-bold text-neutral-900 mb-4 uppercase text-sm tracking-wider">Contact</h4>
      <ul class="space-y-3">
        <li class="flex items-start gap-3">
          <i data-lucide="map-pin" class="w-5 h-5 text-[#00AEEF] shrink-0 mt-0.5"></i>
          <span set:html={address}></span>
        </li>
        <li class="flex items-center gap-3">
          <i data-lucide="phone" class="w-5 h-5 text-[#00AEEF] shrink-0"></i>
          <span>{phone}</span>
        </li>
        <li class="flex items-center gap-3">
          <i data-lucide="mail" class="w-5 h-5 text-[#00AEEF] shrink-0"></i>
          <span>{email}</span>
        </li>
      </ul>
    </div>
  </div>
  <div class="max-w-7xl mx-auto px-6 border-t border-neutral-100 mt-12 pt-8 text-sm text-neutral-500 flex flex-col md:flex-row justify-between items-center gap-4">
    <p>© 2026 BugZero. Tous droits réservés.</p>
    <div class="flex gap-6">
      <a href="/mentions-legales/" class="hover:text-neutral-900">Mentions légales</a>
      <a href="/politique-confidentialite/" class="hover:text-neutral-900">Politique de confidentialité</a>
    </div>
  </div>
</footer>