---
export interface Step {
  number: string;
  title: string;
  description: string;
  circled?: boolean;
}

export interface Props {
  title: string;
  description?: string;
  steps: Step[];
}

const { title, description, steps } = Astro.props;
---

<section class="py-24 bg-[#EEF9FF] border-y border-neutral-200">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="font-sans text-4xl font-bold tracking-tight text-neutral-900 mb-4">{title}</h2>
      {description && <p class="font-sans text-xl text-neutral-600 max-w-2xl mx-auto">{description}</p>}
    </div>
    <div class="grid md:grid-cols-3 gap-8 relative">
      <div class="hidden md:block absolute top-12 left-[15%] right-[15%] h-0.5 bg-[#00AEEF]/20 z-0"></div>
      {steps.map((step, i) => (
        <div class="relative z-10 flex flex-col items-center text-center">
          <div class={`w-24 h-24 ${step.circled ? 'bg-[#00AEEF] border-4 border-[#EEF9FF]' : 'bg-white border-4 border-[#EEF9FF]'} rounded-full shadow-md flex items-center justify-center mb-6 ${step.circled ? 'text-white' : i === 2 ? 'text-[#C4D600]' : 'text-[#00AEEF]'}`}>
            <span class="text-3xl font-bold">{step.number}</span>
          </div>
          <h3 class="text-xl font-bold text-neutral-900 mb-3">{step.title}</h3>
          <p class="text-neutral-600">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
