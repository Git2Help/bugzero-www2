---
export interface Props {
  title?: string;
}

const { title = "BugZero | Infogérance informatique" } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <script src="https://cdn.tailwindcss.com" is:inline></script>
    <script src="https://unpkg.com/lucide@latest" is:inline></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" is:inline />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin is:inline />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" is:inline />
    <style is:inline>
      .font-sans { font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; }
    </style>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='20' fill='%2300AEEF'/><text x='50' y='70' font-size='65' font-family='sans-serif' font-weight='bold' fill='white' text-anchor='middle'>B</text></svg>" is:inline />
  </head>
  <body class="font-sans text-neutral-800 bg-white antialiased overflow-x-hidden relative">
    <slot />
    <script is:inline>
      lucide.createIcons();
    </script>
  </body>
</html>
