---
export interface Props {
  badge?: string;
  title: string;
  titleHighlight: string;
  description: string;
  ctaPrimary?: { label: string; href: string };
  ctaSecondary?: { label: string; href: string };
  showStatusCard?: boolean;
}

const { badge, title, titleHighlight, description, ctaPrimary, ctaSecondary, showStatusCard = true } = Astro.props;
---

<section class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 px-6 overflow-hidden z-10">
  <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
    <div class="relative z-10 space-y-8">
      {badge && (
        <div class="inline-block px-4 py-1.5 bg-[#EEF9FF] border border-[#00AEEF]/20 rounded-full">
          <span class="font-sans text-[#00AEEF] text-sm font-semibold uppercase tracking-wider">{badge}</span>
        </div>
      )}
      <h1 class="font-sans text-5xl lg:text-7xl font-bold leading-tight tracking-tight text-neutral-900">
        {title}
        <br />
        <span class="text-[#00AEEF]">{titleHighlight}</span>
      </h1>
      <p class="text-xl text-neutral-600 leading-relaxed max-w-lg font-sans">{description}</p>
      <div class="flex flex-wrap gap-4 pt-4">
        {ctaPrimary && (
          <a href={ctaPrimary.href} class="px-8 py-4 bg-[#00AEEF] text-white font-sans font-medium text-lg rounded-md hover:bg-[#0090C0] transition-all">
            {ctaPrimary.label}
          </a>
        )}
        {ctaSecondary && (
          <a href={ctaSecondary.href} class="px-8 py-4 bg-white border-2 border-neutral-200 text-neutral-700 font-sans font-medium text-lg rounded-md hover:border-[#00AEEF] hover:text-[#00AEEF] transition-all">
            {ctaSecondary.label}
          </a>
        )}
      </div>
    </div>
    {showStatusCard && (
      <div class="relative flex justify-center lg:justify-end">
        <div class="w-full max-w-lg bg-white border border-neutral-200 rounded-2xl shadow-xl p-8 relative overflow-hidden">
          <div class="absolute top-0 left-0 w-full h-2 bg-[#C4D600]"></div>
          <div class="flex items-center gap-4 mb-8">
            <div class="w-12 h-12 bg-[#EEF9FF] rounded-lg flex items-center justify-center text-[#00AEEF]">
              <i data-lucide="server" class="w-6 h-6"></i>
            </div>
            <div>
              <h3 class="font-sans font-bold text-xl text-neutral-900">Système opérationnel</h3>
              <p class="font-sans text-sm text-green-600 font-medium flex items-center gap-1">
                <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
                100% en ligne
              </p>
            </div>
          </div>
          <div class="space-y-4">
            <div class="h-4 bg-neutral-100 rounded-full w-full"></div>
            <div class="h-4 bg-neutral-100 rounded-full w-5/6"></div>
            <div class="h-4 bg-neutral-100 rounded-full w-4/6"></div>
          </div>
          <div class="mt-8 pt-8 border-t border-neutral-100 flex items-center justify-between">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-full bg-green-100 flex items-center justify-center">
                <i data-lucide="shield-check" class="w-4 h-4 text-green-600"></i>
              </div>
              <span class="text-sm font-medium text-neutral-600">Sécurité active</span>
            </div>
            <span class="text-sm font-bold text-[#00AEEF]">Protégé</span>
          </div>
        </div>
      </div>
    )}
  </div>
</section>
